# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Template konfigurasi environment variables
# Salin file ini menjadi .env lalu isi nilainya sesuai konfigurasi Anda.
#
#   cp .env.example .env
#

# ─── Database (MySQL / TiDB) ──────────────────────────────────────────────────
# Digunakan oleh prisma.config.ts untuk migrasi & introspeksi schema:
DATABASE_URL=""

# Digunakan oleh driver adapter Prisma saat runtime:
DB_HOST=""
DB_PORT=""
DB_USER=""
DB_PASSWORD=""
DB_NAME=""

# ─── External AI Service ──────────────────────────────────────────────────────
# URL endpoint layanan prediksi sampah eksternal:
API_URL=""

# API Key untuk autentikasi ke layanan AI:
API_KEY=""
